{
  "name": "ChatGPT Voyager",
  "short_name": "ChatGPT Voyager",
  "description": "Personal ChatGPT conversation manager",
  "action": {
    "default_icon": "public/dev-icon-32.png",
    "default_popup": "src/pages/popup/index.html"
  },
  "icons": {
    "128": "public/dev-icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "contentStyle.css",
        "dev-icon-128.png",
        "dev-icon-32.png",
        "icon-32.png",
        "icon-128.png",
        "fetchInterceptor.js",
        "prevent-auto-scroll.js",
        "assets/*.js",
        "assets/*.png"
      ],
      "matches": ["https://chatgpt.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["src/pages/content/injectedChatGPTCaptureScript.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": ["src/pages/content/index.tsx"],
      "css": ["contentStyle.css"]
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://lh3.google.com/*",
    "https://*.ggpht.com/*"
  ],
  "oauth2": {
    "client_id": "462948120910-vvunu0k3b4vi37u23mqnh77mbgdjcg78.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "background": {
    "service_worker": "src/pages/background/index.ts",
    "type": "module"
  },
  "version": "0.1.0"
}
